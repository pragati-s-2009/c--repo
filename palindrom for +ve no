class Solution {
public:
    bool isPalindrome(int x) {
        int original=x;
        int r;
        double ans=0;
        while(x>0){
            r=x%10;
            ans=(ans*10)+r;
            x=x/10;

        }
        if(ans==original){
            return true;
        }
        else{
            return false;
        }
    }
};
